{
  "name": "nodel-webui-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run typecheck && npm run test && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "deploy:preview": "npm run build && node ./scripts/deploy.mjs --target ./build/deploy-preview",
    "deploy": "npm run build && node ./scripts/deploy.mjs"
  },
  "dependencies": {
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "jquery": "^3.7.1",
    "jsviews": "^1.0.16"
  },
  "devDependencies": {
    "@types/jquery": "^3.5.33",
    "@types/node": "^22.15.17",
    "autoprefixer": "^10.4.21",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.2"
  }
}
