{
  "name": "nodel-webui-v2",
  "version": "0.1.0",
  "description": "The next-generation web interface for Nodel",
  "license": "MPL-2.0",
  "repository": "github:mcartmel/nodel-webui-v2",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "check:jsviews": "node ./scripts/check-jsviews-templates.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run typecheck && npm run check:jsviews && npm run test && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "deploy:preview": "npm run build && node ./scripts/deploy.mjs --target ./build/deploy-preview",
    "deploy:catalog:preview": "npm run build && node ./scripts/deploy-catalog.mjs --target ./build/deploy-catalog-preview",
    "deploy:catalog": "npm run build && node ./scripts/deploy-catalog.mjs",
    "deploy": "npm run build && node ./scripts/deploy.mjs"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@lezer/highlight": "^1.2.3",
    "chart.js": "^4.5.1",
    "codemirror": "^6.0.2",
    "identicon.js": "^2.3.3",
    "jquery": "^3.7.1",
    "jsviews": "^1.0.16",
    "pagedown": "^1.1.0",
    "xxhashjs": "^0.2.2"
  },
  "devDependencies": {
    "@types/jquery": "^3.5.33",
    "@types/node": "^22.15.17",
    "autoprefixer": "^10.4.21",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.2"
  }
}
